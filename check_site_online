#!/usr/bin/env bash

URL="$1"

if [ -z "$URL" ]; then
  echo "Uso: $0 <url>"
  exit 1
fi

while true; do
  STATUS=$(curl -s -o /dev/null -w "%{http_code}" "$URL")

  if [ "$STATUS" = "200" ]; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') OK - $URL"
  else
    echo "$(date '+%Y-%m-%d %H:%M:%S') ERROR $STATUS - $URL"
  fi

  sleep 1
done
